# Copy to `.env.production.local` (gitignored) or set in CI before `npm run build`.
# Vite only exposes variables prefixed with VITE_.

# Option A — one API Gateway for everything (same invoke URL for all routes):
# VITE_API_BASE=https://abc123xyz.execute-api.eu-central-1.amazonaws.com/dev

# Option B — separate APIs (typical RS School / microservice tasks):
# VITE_API_BFF=https://....execute-api.eu-central-1.amazonaws.com/dev
# VITE_API_ORDER=https://....execute-api.eu-central-1.amazonaws.com/dev
# VITE_API_CART=https://....execute-api.eu-central-1.amazonaws.com/dev
# VITE_API_IMPORT=https://....execute-api.eu-central-1.amazonaws.com/dev
# VITE_API_PRODUCT=https://....execute-api.eu-central-1.amazonaws.com/dev
